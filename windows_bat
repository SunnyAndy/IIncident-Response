:CheckSignature
"%~d0\Windows\7.Collect File Tools\signtool.exe" verify /a /q "%~1"
if errorlevel 1 echo %~1 >> "%OUTPUT_FOLDER%\signtool.txt"
if errorlevel 2 echo %~1 >> "%OUTPUT_FOLDER%\signtool.txt"

EXIT /B 0




