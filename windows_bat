:: user profile 
:user_profile
mkdir %OUTPUT_FOLDER%\ntuser
FOR /F "tokens=*" %%G IN ('dir /b ^"%SystemDrive%\Users\*^"') DO echo %%G>> %OUTPUT_FOLDER%\ntuser\list.txt
type %OUTPUT_FOLDER%\ntuser\list.txt | find /V /I " " >> %OUTPUT_FOLDER%\ntuser\list2.txt
                  
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO mkdir %OUTPUT_FOLDER%\ntuser\%%G
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\NTUSER.DAT /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G 
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\NTUSER.DAT.LOG1 /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G 
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\NTUSER.DAT.LOG2 /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G 
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\AppData\Local\Microsoft\Windows\UsrClass.dat /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\AppData\Local\Microsoft\Windows\UsrClass.dat.LOG1 /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G
FOR /F "eol= delims=" %%G IN (%OUTPUT_FOLDER%\ntuser\list2.txt) DO %RAW_COPY% /FileNamePath:%SystemDrive%\Users\%%G\AppData\Local\Microsoft\Windows\UsrClass.dat.LOG2 /OutputPath:%OUTPUT_FOLDER%\ntuser\%%G

EXIT /B 0
